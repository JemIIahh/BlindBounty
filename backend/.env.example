# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=https://www.blindmarket.xyz

# Redis
REDIS_URL=redis://localhost:6379

# 0G Chain RPC
OG_RPC_URL=https://evmrpc-testnet.0g.ai
OG_CHAIN_ID=16602

# Contract addresses (deploy to testnet first, then fill these in)
BLIND_ESCROW_ADDRESS=0x037529B296a89E6Dd1abAF84D413cb2dD70C5be5
TASK_REGISTRY_ADDRESS=0x25Bc5be1F8Ab44ADfb7a6Ce1362d37408E74DA95
BLIND_REPUTATION_ADDRESS=0x3d0374963DaaD43e31d42373eb11156A8e8ce2Ff
VALIDATOR_POOL_ADDRESS=0xBBE1b3736147C849455467E558245b04f01790E6

# Auth
# Privy is the identity provider for browser users — required.
# Get an app ID from https://dashboard.privy.io.
PRIVY_APP_ID=

# Shared API key for agent / SDK / CLI callers. Send as `X-API-Key` or
# `Authorization: Bearer`. Generate with: `openssl rand -hex 32`.
AGENT_API_KEY=

# Used only by routes/registration.ts to mint per-agent CLI tokens
# (device-flow registration). Not accepted as end-user auth.
JWT_SECRET=change-me-to-a-random-64-char-string

# Founder wallets (comma-separated, lowercase) — gate /metrics + funnel API.
# Empty = no one is a founder (fail-closed).
FOUNDER_ADDRESSES=

# CORS
CORS_ORIGIN=http://localhost:5173

# 0G Storage (Phase 3)
# Leave empty to use local file fallback (dev mode)
OG_STORAGE_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai
OG_STORAGE_PRIVATE_KEY=

# 0G Compute / Sealed Inference (Phase 4)
# Leave empty to use local stub (auto-passes all verifications in dev mode)
OG_COMPUTE_PRIVATE_KEY=
OG_COMPUTE_RPC_URL=https://evmrpc-testnet.0g.ai
# Optional: preferred provider address (leave empty for auto-select)
OG_COMPUTE_PROVIDER_ADDRESS=
